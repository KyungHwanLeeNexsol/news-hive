# Database
# 로컬: postgresql://postgres:postgres@localhost:5432/news_hive
# Neon: postgresql://user:pass@ep-xxx.region.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/news_hive

# Naver API (https://developers.naver.com 에서 발급)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Google Gemini API (https://aistudio.google.com/apikey) — 무료 플랜 3키 rotation
GEMINI_API_KEY=your_gemini_api_key_1
GEMINI_API_KEY_2=your_gemini_api_key_2
GEMINI_API_KEY_3=your_gemini_api_key_3

# Scheduler
NEWS_CRAWL_INTERVAL_MINUTES=30

# Admin password for AI Fund Manager access
ADMIN_PASSWORD=your_admin_password

# Frontend URL (CORS 허용 - Vercel 배포 시 Vercel URL로 변경)
FRONTEND_URL=http://localhost:3000
