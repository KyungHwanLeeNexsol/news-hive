# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_news_tracker

# Naver API (https://developers.naver.com 에서 발급)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# NewsAPI (https://newsapi.org 에서 발급)
NEWSAPI_KEY=your_newsapi_key

# Google Gemini API (https://aistudio.google.com/apikey 에서 발급)
GEMINI_API_KEY=your_gemini_api_key

# Scheduler
NEWS_CRAWL_INTERVAL_MINUTES=30
